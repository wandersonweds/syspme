
# Banco de Dados 
# Conexão MySQL local (sem senha):
DATABASE_URL="mysql://root:@localhost:3306/syspme"
# Exemplo com senha:
# DATABASE_URL="mysql://root:suasenha@localhost:3306/syspme"

# Autenticação JWT
# Segredo para assinar tokens de sessão. Trocarf em produção:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="syspme-secret-key-change-in-production"

# Ambiente 
NODE_ENV="development"

